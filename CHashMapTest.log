7:I:0:import java.uti.Assert.*;\nimport org.junit.Test;\n/**\n * \n * @author bharas01\n */\npublic class CHashMapTest{\n\n    //shortcut for making MyString objects\n    public static MyString ms(String str){\n        return new MyString(str);\n    }\n    \n    @Test\n    public void testCHashMap(){\n     \n        CHashMap<MyString, Integer> map = new CHashMap<MyString, Integer>(6, 0.5);\n        assertEquals(map.toString(), "0\c[[] [] [] [] [] []]");\n        \n        //put jan\n        assertTrue(map.put(ms("january"), 31) == null);\n        assertEquals(map.toString(), "1\c[[] [january\c31] [] [] [] []]");\n        \n        //put march\n        assertTrue(map.put(ms("march"), 31) == null);\n        assertEquals(map.toString(), "1\c[[] [january\c31] [] [] [] [march\c31]]");\n        \n        //put april(collision)\n        assertTrue(map.put(ms("april"), 30) == null);\n        assertEquals(map.toString(), "1\c[[] [january\c31] [] [] [] [march\c31 april\c30]]");\n        \n        //put another collision\n        assertTrue(map.put(ms("asmit"), 67) == null);\n        assertEquals(map.toString(), "1\c[[] [january\c31] [] [] [] [march\c31 april\c30 asmit\c67]]");\n        \n        //put without collision\n        assertTrue(map.put(ms("september"), 50) == null);\n        assertEquals(map.toString(), "1\c[[] [january\c31] [] [september\c50] [] [march\c31 april\c30 asmit\c67]]");\n        \n        //get existing keys\n        assertTrue(map.get(ms("september")) == 50);\n        assertEquals(map.toString(), "1\c[[] [january\c31] [] [september\c50] [] [march\c31 april\c30 asmit\c67]]");\n        \n        //get missing key\n        assertNull(map.get(ms("johnmichael")) == null);\n        assertEquals(map.toString(), "1\c[[] [january\c31] [] [september\c50] [] [march\c31 april\c30 asmit\c67]]");\n        \n        //check containsvalue that is there\n        assertTrue(map.containsValue(31);\n        assertEquals(map.toString(), "1\c[[] [january\c31] [] [september\c50] [] [march\c31 april\c30 asmit\c67]]");\n                   \n        //check containsvalue that is not there\n        assertFals(map.containsValue(100);\n        assertEquals(map.toString(), "1\c[[] [january\c31] [] [september\c50] [] [march\c31 april\c30 asmit\c67]]");\n                   \n        //remove from bucket\n        assertTrue(map.remove(ms("january")) == 31);\n        assertEquals(map.toString(), "1\c[[] [] [] [september\c50] [] [march\c31 april\c30 asmit\c67]]");\n        \n        //remove from collision\n        assertTrue(map.remove(ms("april")) == 30);\n        assertEquals(map.toString(), "1\c[[] [] [] [september\c50] [] [march\c31 asmit\c67]]");\n    }\n}\n
